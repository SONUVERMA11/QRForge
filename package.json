{
  "name": "qrforge",
  "version": "1.0.0",
  "description": "QRForge — The World's Most Advanced Dynamic QR Code Platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node --watch server/index.js",
    "client:dev": "cd client && npm run dev",
    "server:start": "node server/index.js",
    "setup": "npm install && cd client && npm install",
    "db:init": "node server/db/init.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "geoip-lite": "^1.4.10",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "ua-parser-js": "^2.0.3",
    "uuid": "^11.1.0"
  }
}
